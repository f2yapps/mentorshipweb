# Supabase (required)
# Get these from your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Supabase service role key (only for server-side admin operations; never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Contact form email (Resend). Without RESEND_API_KEY, form still returns success but no email is sent.
# Get API key at https://resend.com . Add support@f2yapps.com (or your inbox) as recipient.
# RESEND_API_KEY=re_xxxx
# CONTACT_EMAIL=support@f2yapps.com
# RESEND_FROM_EMAIL=onboarding@resend.dev

# Email verification: To avoid "localhost refused to connect" after verifying email in production,
# set Supabase Dashboard -> Authentication -> URL Configuration -> Site URL to your production URL
# (e.g. https://your-app.vercel.app) and add that origin to Redirect URLs.
